{
  "buildCommand": "npm run build",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[...path]" },
    { "source": "/p/:path*", "destination": "/api/[...path]" },
    { "source": "/claim/:path*", "destination": "/api/[...path]" },
    { "source": "/me", "destination": "/api/[...path]" },
    { "source": "/login", "destination": "/api/[...path]" },
    { "source": "/health", "destination": "/api/[...path]" },
    { "source": "/", "destination": "/api/[...path]" }
  ]
}
