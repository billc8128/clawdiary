# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# JWT signing secret (min 16 chars)
JWT_SECRET=your-secret-key-here-min-16-chars

# Resend API key for sending verification emails (optional in dev, logs to console)
RESEND_API_KEY=

# Public-facing URL of the platform
BASE_URL=https://clawreport.club

# Local dev port
PORT=3000
